# 上游 API 地址
UPSTREAM_BASE_URL=http://127.0.0.1:3000

# 上游认证头（如需）
# UPSTREAM_AUTH_HEADER=Bearer sk-your-key-here

# 管理 API Token（HOST 非本机地址时必填）
# ADMIN_TOKEN=change-me-admin-token

# /v1 代理访问 Token（HOST 非本机地址时必填）
# BRIDGE_API_KEY=change-me-bridge-key

# 模型映射：外部名 → 上游名
MODEL_MAP_JSON={"deepseek-chat":"deepseek-v4-flash","deepseek-coder":"deepseek-v4-flash","deepseek-think":"deepseek-v4-pro"}

# 支持原生 tool calling 的上游模型
NATIVE_TOOL_MODELS_JSON=["deepseek-v4-pro"]

# /v1/models 返回的模型列表
PUBLIC_MODEL_IDS_JSON=["deepseek-chat","deepseek-coder","deepseek-think","deepseek-v4-flash","deepseek-v4-pro"]

# 是否直通未映射模型
ALLOW_UNMAPPED_MODEL_PASSTHROUGH=true

# 上游超时（秒）
UPSTREAM_TIMEOUT_SECONDS=240

# 监听
HOST=127.0.0.1
PORT=8080

# FC 解析失败时是否自动重试（默认开启）
FC_ERROR_RETRY=true

# FC 解析重试最大次数（默认 3）
FC_ERROR_RETRY_MAX_ATTEMPTS=3

# 重试间隔秒数（默认 0）
# RETRY_DELAY_SECONDS=0
